# ai-server 환경변수 (코드에서 실제 사용하는 것만). 복사해서 .env 로 채우세요.
# load_dotenv() 가 .env 를 읽고, 컨테이너에선 docker run -e / compose env 로도 주입 가능.

# ── DB (RDS PostgreSQL) ──────────────────────────────
# asyncpg 형식. 배포 시 RDS 엔드포인트로 교체.
DB_URL=postgresql://wooriport:wooriport1234@localhost:5432/wooriport

# ── Redis (세션) ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── LLM (OpenAI) ─────────────────────────────────────
OPENAI_API_KEY=sk-...                # 필수
LLM_MODEL=gpt-4o                     # 선택 (기본 gpt-4o)
LLM_TEMPERATURE=0.2                  # 선택 (기본 0.2)

# ── 뉴스 검색 (선택) ─────────────────────────────────
# 없으면 리포트의 뉴스 섹션이 빈 문자열로 처리됨(에러 아님).
TAVILY_API_KEY=

# ── 로깅 ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ⚠️ CORS 허용 origin (배포 시 CloudFront 도메인 추가). 콤마 구분.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 참고: 기존 .env 의 OPENROUTER_API_KEY / KAFKA_* / AGENT_TIMEOUT_* 는
#       현재 app/ 코드에서 사용하지 않습니다(AGENT_TIMEOUT 은 app/core/config.py 상수).
